PORT=3000

# Firebase Realtime Database
FIREBASE_DATABASE_URL=Điền URL của Firebase Realtime Database vào đây

# Firebase Web API Key (dùng cho signInWithPassword)
FIREBASE_API_KEY="Điền Firebase Web API Key vào đây"

# Firebase Storage bucket (dùng để lưu ảnh món/avatar).
# Để trống sẽ tự suy ra <project_id>.appspot.com từ serviceAccountKey.json.
# Nếu project dùng bucket kiểu mới, đặt: <project_id>.firebasestorage.app
FIREBASE_STORAGE_BUCKET=""

# Secret key bảo vệ endpoint đổi mật khẩu
APP_SECRET_KEY="Điền secret key vào đây"

# Email gửi OTP. Chạy local: chỉ cần EMAIL_USER + EMAIL_PASS (Gmail App Password, bật 2FA rồi tạo).
# Deploy Render free: SMTP bị chặn → phải điền thêm BREVO_API_KEY (brevo.com, free 300 email/ngày)
# và verify EMAIL_USER trong Brevo → Senders. Có BREVO_API_KEY thì EMAIL_PASS không dùng tới.
EMAIL_USER="Điền email của bạn vào đây"
EMAIL_PASS="Điền Gmail App Password vào đây"
BREVO_API_KEY=""

# Môi trường (development | production)
NODE_ENV=development